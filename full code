#include "mbed.h"
#include "arm_book_lib.h"
#include <math.h>

typedef enum { NORMAL, WARNING, LOCKDOWN } system_state_t;


int main()
{
    DigitalIn buttons[6] = {D2, D3, D4, D5, D6, D7};
    DigitalOut alarmLed(LED1);         
    DigitalOut incorrectCodeLed(LED3);  
    DigitalOut systemBlockedLed(LED2); 

    for(int i=0; i<6; i++) buttons[i].mode(PullDown); 
    
    alarmLed = ON;
    incorrectCodeLed = OFF;
    systemBlockedLed = OFF;

    Timer stateTimer;
    system_state_t systemState = NORMAL;

    int secretCode[4] = {2, 3, 4, 5}; 
    int adminCode[4] = {1, 1, 1, 1};
    int userEntryIndex = 0; 
    int buttonsPressedThisTry = 0;    
    int incorrectCodes = 0;   
    bool buttonWasPressed = false;  
    int lockdownCount = 0;

    stateTimer.start(); 

    while (true) {
        int currentButton = -1;
    
        for(int i=0; i<6; i++) {
            if (buttons[i]) currentButton = i;
        }

      switch (systemState) {

            case NORMAL:
                if (currentButton != -1 && !buttonWasPressed) {
                    buttonWasPressed = true;
                    buttonsPressedThisTry++;

                   
                    if (currentButton == secretCode[userEntryIndex]) {
                        userEntryIndex++;
                    }

                    if (buttonsPressedThisTry == 4) {
                        if (userEntryIndex == 4) {
                            alarmLed = OFF; 
                            incorrectCodes = 0; 
                            incorrectCodeLed = OFF;
                            } 

                    else {
                        incorrectCodes++;
                        
                           
                            if (incorrectCodes == 3) {
                                systemState = WARNING;
                                stateTimer.reset();

                            } else if (incorrectCodes >= 4) {
                                systemState = LOCKDOWN;
                                lockdownCount++;
                                displayEventLog(lockdownCount);
                                stateTimer.reset();
                               
                            
                            }
                        }
                      
                        userEntryIndex = 0;
                        buttonsPressedThisTry = 0;
                    }
                }
                
                break;
                       
            case WARNING:
               
                incorrectCodeLed = (fmod(stateTimer.read(), 1.0) < 0.5);
                
                if (stateTimer.read() > 30.0) {
                    incorrectCodeLed = OFF;
                    systemState = NORMAL; 
                }
                break;

            case LOCKDOWN:
                systemBlockedLed = ON; 
               
                incorrectCodeLed = (fmod(stateTimer.read(), 0.6) < 0.3);

                if (currentButton != -1 && !buttonWasPressed) {
                    buttonWasPressed = true;
                    if (currentButton == adminCode[userEntryIndex]) {
                        userEntryIndex++;
                    } else {
                        userEntryIndex = 0;
                    }

                    if (userEntryIndex == 4) {
                        systemState = NORMAL;
                        incorrectCodes = 0;
                        userEntryIndex = 0;
                        buttonsPressedThisTry = 0;
                        systemBlockedLed = OFF;
                        incorrectCodeLed = OFF;
              
                        
                    }
                }
                break;
        }

       
        if (currentButton == -1) { 
        buttonWasPressed = false;
            }

        ThisThread::sleep_for(10ms);
   }
}
